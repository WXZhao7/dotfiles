# ~/.config/mako/config

sort=-time
layer=overlay
anchor=top-right

width=360
height=120
margin=10
padding=12
border-size=2
border-radius=8

icons=1
max-icon-size=48

default-timeout=5000
ignore-timeout=1

[urgency=low]
default-timeout=3000

[urgency=normal]
default-timeout=5000

[urgency=high]
default-timeout=0
